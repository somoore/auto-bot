# auto-bot local development environment
# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- App auth (required) ---
# A long random string; the browser uses it once to create a session.
APP_API_TOKEN=change-me-to-a-long-random-string

# --- Voice provider: "nova-sonic" (AWS Bedrock) or "openai" ---
VOICE_PROVIDER=nova-sonic

# --- LiveKit (required for the nova-sonic voice path) ---
# Create a project at https://cloud.livekit.io and paste its URL + keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- AWS Bedrock (Nova Sonic voice + Claude agent runs) ---
# For local dev, an access key works; in production use IAM Roles Anywhere
# (see deploy/terraform/roles-anywhere and deploy/helm). Region must have
# Nova Sonic (us-east-1 or us-west-2; NOT us-east-2).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- OpenAI (only if VOICE_PROVIDER=openai) ---
OPENAI_API_KEY=

# --- Optional integrations (leave blank to disable) ---
# Jira
JIRA_CONFIG_PATH=
JIRA_API_TOKEN=
# GitHub App (for agent code/PR access)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_DEFAULT_REPO=
