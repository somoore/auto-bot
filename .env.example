# auto-bot local development environment
# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- App auth (required) ---
# A long random string; the browser uses it once to create a session.
APP_API_TOKEN=change-me-to-a-long-random-string

# --- SSO (optional): per-user identity from a verified email ---
# By default the app uses the shared APP_API_TOKEN (one identity for everyone).
# To give each user a distinct identity (needed for the meeting host gate and
# multi-user LiveKit), front the app with one of these and set the matching env.
# See docs/deployment.md "Access control" for the full guide.
#
# Cloudflare Access:
#   APP_CF_ACCESS_AUTH=1
#   CF_ACCESS_TEAM_DOMAIN=https://<your-team>.cloudflareaccess.com
#   CF_ACCESS_AUD=<your Access application's AUD tag>
# AWS ALB OIDC / Cognito:
#   APP_ALB_OIDC_AUTH=1
#   APP_ALB_ARN=<your ALB ARN>
# Required allowlist for either SSO option (the app refuses to start open):
#   ALLOWED_EMAILS=alice@example.com,bob@example.com
#   ALLOWED_EMAIL_DOMAINS=example.com
# If a private admin ingress also injects the shared bearer, restrict it to that
# host so SSO-fronted public hosts fail closed:
#   ADMIN_BEARER_HOSTS=admin.internal.example

# --- Voice provider: "nova-sonic" (AWS Bedrock Nova Sonic) ---
VOICE_PROVIDER=nova-sonic

# --- LiveKit (required for the nova-sonic voice path) ---
# Create a project at https://cloud.livekit.io and paste its URL + keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- AWS Bedrock (Nova Sonic voice + Claude agent runs) ---
# For local dev, an access key works; in production use IAM Roles Anywhere
# (see deploy/terraform/roles-anywhere and deploy/helm). Region must have
# Nova Sonic (us-east-1 or us-west-2; NOT us-east-2).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# --- Optional integrations (leave blank to disable) ---
# Jira
JIRA_CONFIG_PATH=
JIRA_API_TOKEN=
# GitHub App (for agent code/PR access)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_DEFAULT_REPO=
