# Voice Provider Selection
# Options: "openai" (default) or "nova-sonic"
VOICE_PROVIDER=openai
APP_ENV=local
APP_AUTH_MODE=token
APP_API_TOKEN=replace-with-random-local-token
APP_ROOM_ID=kanban-meeting
APP_BOARD_ID=default
BOARD_SQLITE_PATH=/srv/data/board.sqlite

# --- OpenAI Realtime Provider ---
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Pion WebRTC settings (OpenAI path only)
CONFERENCE_LOOPBACK_ONLY=1
# PION_NAT1TO1_IP=
# PION_LOG_INFO=all

# --- AWS Nova Sonic 2 Provider ---
AWS_PROFILE=test_AccountA/AdministratorAccess
AWS_REGION=us-east-1
NOVA_SONIC_MODEL=amazon.nova-sonic-v1:0
NOVA_SONIC_VOICE=matthew

# --- LiveKit (Nova Sonic path only) ---
LIVEKIT_DEPLOYMENT_MODE=self-hosted
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_BROWSER_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# LiveKit Cloud switch for AWS:
# LIVEKIT_DEPLOYMENT_MODE=cloud
# LIVEKIT_CLOUD_URL=wss://your-project.livekit.cloud

# Self-hosted AWS DNS/TURN hooks:
# LIVEKIT_DOMAIN_NAME=livekit.example.com
# LIVEKIT_TURN_DOMAIN_NAME=turn.example.com
# LIVEKIT_CERTIFICATE_ARN=arn:aws:acm:us-east-1:...
# LIVEKIT_TURN_CERTIFICATE_ARN=arn:aws:acm:us-east-1:...

# --- Jira Sync (optional) ---
# When set, the server loads the board from Jira on startup and writes board
# mutations back to Jira Cloud REST API v3 and selected Jira Software Agile APIs
# for sprint/rank operations when configured.
# Advanced config fields include board_id, story_points_field, sprint_field,
# epic_link_field, rank_custom_field_id, and custom_field_mappings.
# JIRA_CONFIG_PATH=/absolute/path/to/config/jira.json
# JIRA_CONFIG_JSON={"base_url":"https://your-site.atlassian.net",...}
# JIRA_API_TOKEN=...
# JIRA_WEBHOOK_SECRET=replace-with-random-webhook-secret

# --- Hardening / Audit (optional) ---
# AUDIT_LOG_PATH=/absolute/path/to/audit.jsonl
# TRUST_PROXY_HEADERS=1
