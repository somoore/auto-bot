package examplemodel

import (
	"context"

	"github.com/somoore/auto-bot/internal/core"
)

type Provider struct {
	client *Client
}

func (provider Provider) Name() string {
	return "example-model"
}

func (provider Provider) DisplayName() string {
	return "Example Model"
}

func (provider Provider) Capabilities() core.ModelCapabilities {
	return core.ModelCapabilities{JSON: true, Streaming: false, Modalities: []string{"text"}}
}

func (provider Provider) Complete(ctx context.Context, request core.ModelRequest) (core.ModelResponse, error) {
	return core.ModelResponse{}, nil
}

type Client struct{}
