package exampleconnector

import (
	"context"
	"time"

	"github.com/somoore/auto-bot/internal/core"
)

type Connector struct {
	client *Client
}

func (connector Connector) Name() string {
	return "example"
}

func (connector Connector) DisplayName() string {
	return "Example Connector"
}

func (connector Connector) Capabilities() []core.ConnectorCapability {
	return []core.ConnectorCapability{
		{Name: "example_write", Description: "Write an example record.", Risk: core.RiskMedium, SupportsUndo: true},
	}
}

func (connector Connector) Health(ctx context.Context) core.ConnectorHealth {
	return core.ConnectorHealth{OK: connector.client != nil, Status: "ready", CheckedAt: time.Now().UTC()}
}

func (connector Connector) Execute(ctx context.Context, action core.ConnectorAction) (core.ConnectorResult, error) {
	// Validate action.Type, enforce least privilege, call the external API,
	// and return OK=true only after the API confirms the write.
	return core.ConnectorResult{OK: false, Status: "not_implemented"}, nil
}

func (connector Connector) Undo(ctx context.Context, receipt core.ActionReceipt) (core.ConnectorResult, error) {
	// Use receipt.UndoToken or receipt.ExternalID when the external system supports undo.
	return core.ConnectorResult{OK: false, Status: "not_implemented"}, nil
}

type Client struct{}
